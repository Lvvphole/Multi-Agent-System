{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "skill_registry_schema",
  "title": "Skill Registry Entry",
  "description": "Stage 3 schema for a skill: a versioned durable workflow with input/output contracts, retry behavior, and A4 self-learning-validation fields required before activation.",
  "type": "object",
  "required": ["skill_id", "version", "durable", "input_contract", "output_contract", "retry_policy", "status", "performance_metric", "owner_role"],
  "additionalProperties": false,
  "properties": {
    "skill_id": {"type": "string"},
    "version": {"type": "string"},
    "description": {"type": "string"},
    "durable": {"type": "boolean"},
    "input_contract": {"type": "string", "description": "named schema id the input is validated against"},
    "output_contract": {"type": "string", "description": "named schema id the output is validated against"},
    "retry_policy": {
      "type": "object",
      "required": ["max_retries", "backoff", "retry_scope", "idempotent"],
      "properties": {
        "max_retries": {"type": "integer", "minimum": 0},
        "backoff": {"enum": ["none", "fixed", "exponential"]},
        "retry_scope": {"enum": ["step", "workflow"]},
        "idempotent": {"type": "boolean"},
        "escalate_on_exhaustion": {"const": true}
      }
    },
    "dependencies": {"type": "array", "items": {"type": "string"}},
    "status": {"enum": ["draft", "in_validation", "active", "deprecated", "rolled_back"]},
    "performance_metric": {
      "type": "object",
      "required": ["name", "type", "definition"],
      "properties": {
        "name": {"type": "string"},
        "type": {"const": "continuous", "description": "A4: continuous, not binary, so improvement has a gradient"},
        "definition": {"type": "string", "description": "e.g. stability = mean(per_run_score)/std(per_run_score)"}
      }
    },
    "holdout_validation": {
      "type": "object",
      "required": ["holdout_runs", "metric_value", "passed", "tuning_runs_excluded"],
      "properties": {
        "holdout_runs": {"type": "array", "minItems": 1, "items": {"type": "string"}},
        "metric_value": {"type": "number"},
        "passed": {"type": "boolean"},
        "tuning_runs_excluded": {"const": true, "description": "A4: held-out runs must not overlap tuning runs"}
      }
    },
    "acceptance_bar": {
      "type": "object",
      "required": ["attempt_count", "required_metric"],
      "properties": {
        "attempt_count": {"type": "integer", "minimum": 1},
        "required_metric": {"type": "number", "description": "A4: rises monotonically with attempt_count"}
      }
    },
    "half_life": {
      "type": "object",
      "required": ["estimate_days", "floor_days", "passed"],
      "properties": {
        "estimate_days": {"type": "number"},
        "floor_days": {"type": "number"},
        "passed": {"type": "boolean"}
      }
    },
    "created_at": {"type": "string"},
    "activated_at": {"type": ["string", "null"]},
    "rollback_to": {"type": ["string", "null"]},
    "owner_role": {"type": "string"}
  },
  "allOf": [
    {
      "if": {"properties": {"status": {"const": "active"}}},
      "then": {
        "required": ["holdout_validation", "acceptance_bar", "half_life"],
        "properties": {
          "holdout_validation": {"properties": {"passed": {"const": true}}},
          "half_life": {"properties": {"passed": {"const": true}}}
        },
        "description": "A4: a skill cannot be active unless held-out validation and half-life both passed and the attempt bar is recorded"
      }
    }
  ]
}
