{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "loop_registry_schema",
  "title": "Loop Registry Entry",
  "description": "Stage 3 schema for registering a loop. A loop is a pure decision function over persisted state; it performs no side effects.",
  "type": "object",
  "required": ["loop_id", "trigger", "state_reads", "decision_points", "next_action_logic", "stop_conditions", "owner_role"],
  "additionalProperties": false,
  "properties": {
    "loop_id": {"type": "string"},
    "description": {"type": "string"},
    "trigger": {
      "type": "object",
      "required": ["type", "spec"],
      "properties": {
        "type": {"enum": ["scheduled", "event", "manual"]},
        "spec": {"type": "string", "description": "cron/interval, event source, or manual handle"}
      }
    },
    "state_reads": {
      "type": "array", "minItems": 1,
      "items": {"type": "string"},
      "description": "persisted inputs the loop reads (e.g. state_store, project_memory, gate_log)"
    },
    "decision_points": {
      "type": "array", "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "condition"],
        "properties": {"id": {"type": "string"}, "condition": {"type": "string"}}
      }
    },
    "next_action_logic": {
      "type": "string",
      "description": "deterministic mapping from (state, decision_points) to one of: <action> | STOP | ESCALATE"
    },
    "max_iterations": {"type": "integer", "minimum": 1},
    "stop_conditions": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "owner_role": {"type": "string"},
    "side_effects_allowed": {"const": false, "description": "loops never perform side effects"}
  }
}
